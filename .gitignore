# Dependencies (Netlify installs these during deploy)
node_modules/

# Secrets — keys live in Netlify env vars, never in the repo
.env
.env.*
!.env.example

# Netlify local/build artifacts
.netlify/

# Production build output (generated by `npm run build`)
dist/

# Vendored-lib download scratch
morphdom-tmp.js

# Editor / OS junk
.DS_Store
Thumbs.db
*.swp

# Dev/scratch — never deploy (kept in the sibling "SCWP V3 - dev-not-deployed" folder)
*.bak-*
_preview-review.html
_studio-preview.html
_design-samples.html
_tmp_smoke.js
scan.html
icons/converter.html
