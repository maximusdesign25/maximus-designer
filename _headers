# ─────────────────────────────────────────────────────────────
# MAXIMUS PRO · Netlify headers
# Caching strategy:
#   • HTML + sw.js + manifest: no-cache (always check for updates)
#   • Static assets fingerprinted by content: 1yr immutable (none yet, but ready)
# Security hardening + PWA correctness.
# ─────────────────────────────────────────────────────────────

# Global security headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), geolocation=(), microphone=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  X-Robots-Tag: noindex

# Index — always revalidate so updates propagate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
  Content-Type: text/html; charset=utf-8

# Root — same as index.html
/
  Cache-Control: public, max-age=0, must-revalidate

# Service worker — never cache, scope at root
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Content-Type: application/javascript; charset=utf-8
  Service-Worker-Allowed: /

# PWA manifest
/manifest.webmanifest
  Cache-Control: public, max-age=3600
  Content-Type: application/manifest+json; charset=utf-8

# Static assets folder (if you add /assets/* with fingerprinted filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
